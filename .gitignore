# ============================================================================
# SHAREPOINT SITES TERRAFORM PROJECT - GITIGNORE
# ============================================================================
# This file specifies which files Git should ignore (not track).
# This is important for security and to avoid committing unnecessary files.
#
# SECURITY NOTICE: This file is designed to prevent accidental commits of
# sensitive data. Always review staged files before committing!
#
# Last updated: 2026-03-05
# ============================================================================

# ============================================================================
# 🔐 SENSITIVE FILES - NEVER COMMIT THESE!
# ============================================================================
# These patterns catch common sensitive file types. If you create a new
# sensitive file type, add it here immediately!

# Terraform variables with actual values (contains secrets)
terraform.tfvars
*.tfvars
!terraform.tfvars.example
!*.tfvars.example

# Environment files (may contain API keys, passwords, connection strings)
.env
.env.*
.env.local
.env.development
.env.production
.env.staging
.env.test
*.local.settings.json
local.settings.json
!.env.example
!.env.template

# Secrets and credentials files
secrets.json
secrets.yaml
secrets.yml
**/secrets/
credentials.json
credentials.yaml
service-account*.json

# Azure-specific sensitive files
azure.json
azureauth.json
.azure/
azure-credentials.json
serviceprincipal.json

# AWS credentials (in case of multi-cloud)
.aws/
aws-credentials
credentials.csv

# Google Cloud credentials
*.json.enc
gcloud-service-key.json
google-credentials.json

# Generic credential patterns
*.secret
*.secrets
*secret*.json
*secret*.yaml
*secret*.yml
*password*
*credential*
*credentials*
*.pem
*.key
*.crt
*.cer
*.pfx
